# Rankwise ERP — Environment Variables
# Copy this file to .env.local and fill in your Supabase project values

# ── Supabase ──────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # server-only, never expose

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Rankwise

# ── WhatsApp Business API (Phase 5) ──────────────────────────
# WHATSAPP_BUSINESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# ── News / Current Affairs API (Phase 6) ─────────────────────
# NEWS_API_KEY=
# PIB_RSS_FEED_URL=https://pib.gov.in/RssMain.aspx

# ── AI (Phase 4) ──────────────────────────────────────────────
# ANTHROPIC_API_KEY=
