# ─────────────────────────────────────────────────────────────
# RANKWISE — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Rankwise

# ── Anthropic (Phase 4 — Visual Solver) ───────────────────────
# Get from: https://console.anthropic.com
# Without this key the solver runs in demo mode with mock answers
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── WhatsApp Business API (Phase 5) ───────────────────────────
# WHATSAPP_BUSINESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# ── News / Current Affairs (Phase 6) ─────────────────────────
# NEWS_API_KEY=
